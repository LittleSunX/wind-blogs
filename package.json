{
  "name": "wind-blogs",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run posts:generate && vite",
    "test": "npm run posts:generate && vitest run",
    "test:watch": "npm run posts:generate && vitest",
    "test:e2e": "playwright test",
    "build": "tsc && npm run posts:check && npm run posts:generate && vite build && npm run rss && npm run seo:assets",
    "preview": "vite preview",
    "posts:check": "npx tsx scripts/check-posts.ts",
    "rss": "npx tsx scripts/generate-rss.ts",
    "seo:assets": "npx tsx scripts/generate-seo-assets.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\"",
    "type-check": "tsc --noEmit",
    "posts:generate": "npx tsx scripts/generate-post-index.ts"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.22.0",
    "react-syntax-highlighter": "^15.5.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.0.3",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.0.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.53.0",
    "vite": "^5.4.2",
    "vitest": "^4.0.18"
  }
}
